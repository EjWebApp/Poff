{
  "expo": {
    "name": "Poff",
    "slug": "poff",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/main_char.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffef9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crint.poff.app",
      "infoPlist": {}
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffef9"
      },
      "package": "com.crint.poff.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#d97706"
        }
      ],
      "expo-asset"
    ],
    "scheme": "poff"
  }
}
